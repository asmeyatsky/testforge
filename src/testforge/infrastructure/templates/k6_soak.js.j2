// Auto-generated k6 soak test by TestForge
// Validates system stability under sustained load

import http from 'k6/http';
import { check, sleep } from 'k6';
import { Rate } from 'k6/metrics';

const errorRate = new Rate('errors');

const BASE_URL = __ENV.BASE_URL || 'http://localhost:8000';

export const options = {
  stages: [
    { duration: '2m', target: 10 },   // ramp up
    { duration: '30m', target: 10 },   // sustained load
    { duration: '2m', target: 0 },     // ramp down
  ],
  thresholds: {
    errors: ['rate<0.01'],              // <1% error rate
    http_req_duration: ['p(95)<2000'],  // 95th percentile < 2s
  },
};

{% if endpoints %}
const ENDPOINTS = [
  {% for ep in endpoints %}
  { method: '{{ ep.method }}', path: '{{ ep.path }}', name: '{{ ep.name }}' },
  {% endfor %}
];

export default function () {
  for (const ep of ENDPOINTS) {
    const url = `${BASE_URL}${ep.path}`;
    let res;

    switch (ep.method) {
      case 'POST':
        res = http.post(url, JSON.stringify({}), {
          headers: { 'Content-Type': 'application/json' },
          tags: { name: ep.name },
        });
        break;
      case 'PUT':
        res = http.put(url, JSON.stringify({}), {
          headers: { 'Content-Type': 'application/json' },
          tags: { name: ep.name },
        });
        break;
      case 'DELETE':
        res = http.del(url, null, { tags: { name: ep.name } });
        break;
      default:
        res = http.get(url, { tags: { name: ep.name } });
    }

    const success = check(res, {
      [`${ep.name} status OK`]: (r) => r.status >= 200 && r.status < 400,
      [`${ep.name} response time < 2s`]: (r) => r.timings.duration < 2000,
    });

    errorRate.add(!success);
  }

  sleep(1);
}
{% else %}
export default function () {
  const res = http.get(`${BASE_URL}/`);
  check(res, { 'status is 200': (r) => r.status === 200 });
  sleep(1);
}
{% endif %}
